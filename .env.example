# ─── BrainForge Environment Configuration ─────────────────────
# Copy this file to .env and fill in your values

# MySQL Database
DB_HOST=db
DB_USER=brainforge
DB_PASS=changeme_secure_password
DB_NAME=brain_training

# AIMLAPI Configuration
AIMLAPI_KEY=YOUR_AIMLAPI_KEY_HERE
AIMLAPI_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# App Settings
NEW_GENERATION_CHANCE=30
DOCUMENTS_PER_PAGE=20

# MySQL Root Password (used by docker-compose for DB init)
MYSQL_ROOT_PASSWORD=changeme_root_password
